div(role="toolbar" aria-label!="{label}" aria-orientation!="{orientation}" class!="{classes}")
	| {@render children?.()}

<script>
	import { cn } from '@human-synthesis/norns-ui/cn'

	{
		orientation = 'horizontal'
		label
		children
		class: extra = ''
	} := $props()

	classes := cn 'toolbar', `toolbar-${orientation}`, extra
</script>
