button(
	type!="{type}"
	class!="{classes}"
	disabled!="{disabled || loading}"
	onclick!="{onclick}"
	aria-busy!="{loading ? 'true' : undefined}"
)
	+if('loading')
		span.ui-spinner(aria-hidden="true")
	+if('!loading && icon')
		Icon(name!="{icon}" size!="{iconSize}")
	+if('!loading && leading')
		| {@render leading()}
	+if('children')
		| {@render children()}
	+if('!loading && trailing')
		| {@render trailing()}

<script>
	import { cn } from '@human-synthesis/norns-ui/cn'
	import Icon from './Icon.n'

	{
		variant = 'primary'
		size = 'md'
		loading = false
		disabled = false
		type = 'button'
		onclick = undefined
		icon
		children
		leading
		trailing
		class: extra = ''
	} := $props()

	classes := cn 'btn', `btn-${variant}`, size !== 'md' && `btn-${size}`, extra
	iconSize := size === 'sm' ? 'size-3.5' : size === 'lg' ? 'size-5' : 'size-4'
</script>
